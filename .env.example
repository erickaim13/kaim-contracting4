# Kaim Contracting — server-side environment variables (Vercel project settings)
# Copy to .env.local for local dev. Never commit real secrets.

# --- Supabase (CRM data store) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Gmail SMTP for confirmation emails) ---
GMAIL_APP_PASSWORD=

# --- Meta Lead Ads webhook (/api/meta-lead-webhook) ---
# Shared token you also type into Meta's webhook "Verify Token" field.
META_VERIFY_TOKEN=
# Meta App Secret — used to verify the X-Hub-Signature-256 on incoming POSTs.
META_APP_SECRET=
# Long-lived Page access token with leads_retrieval permission.
PAGE_ACCESS_TOKEN=
